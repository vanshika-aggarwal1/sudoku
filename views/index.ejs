<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="css/styles.css" />
    <title>Sudoku</title>
  </head>
  <body>
    <nav class="navbar">
      <div class="container text-center">
        <h1 id="title">SUDOKU</h1>
      </div>
    </nav>

    <section class="container text-center">
      <!-- row1 -->
      <div class="row">
        <div class="col">
            <button class="card" onclick="go('easy')">
              <div class="card-body">Easy</div>
            </button>
        </div>

        <div class="col">
            <button class="card" onclick="go('medium')">
              <div class="card-body">Medium</div>
            </button>
        </div>

        <div class="col">
            <button class="card" onclick="go('hard')">
              <div class="card-body">Hard</div>
            </button>
        </div>
      </div>
    </section>
  </body>


  <script>
    function go(difficulty) {
      window.location.href='/next/' + difficulty
    }
  </script>
</html>
